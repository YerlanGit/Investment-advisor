# ──────────────────────────────────────────────────────────────────────────
# Freedom Broker (Tradernet) read-only API credentials
# ──────────────────────────────────────────────────────────────────────────
# Generate the pair in Tradernet:
#   Account → Settings → API access → "Issue new API key (read-only)"
#
# NEVER commit the populated .env file — it is gitignored.

TRADERNET_PUBLIC_KEY=your_public_key_here
TRADERNET_SECRET_KEY=your_secret_key_here
TRADERNET_ENV=live   # or: demo

# Legacy aliases consumed by the Telegram bot / Cloud Run secrets binding.
# Either set these, or set the TRADERNET_* pair above — the package reads both.
FREEDOM_API_KEY=your_public_key_here
FREEDOM_API_SECRET=your_secret_key_here
