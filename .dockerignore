# ── Version control ───────────────────────────────────────────────────────────
.git
.gitignore

# ── Secrets — NEVER send to Docker build context ──────────────────────────────
.env
.env.*
ANTHROPIC_API_KEY.env
*.pem
*.key

# ── Local databases (ephemeral; Cloud Run uses Secret Manager + Cloud SQL) ────
data/tokenomics.db
data/user_reports/
users_vault.db

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Dev tooling ───────────────────────────────────────────────────────────────
.venv/
venv/
env/
.tox/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# ── Tests & docs ──────────────────────────────────────────────────────────────
tests/
*.md
assets/

# ── Rust workspace (not part of the Python bot) ───────────────────────────────
rust/

# ── Claude Code session files ─────────────────────────────────────────────────
.claude/
.port_sessions/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
