# ── Version control ───────────────────────────────────────────────────────────
.git
.gitignore

# ── Secrets — NEVER send to Docker build context ──────────────────────────────
.env
.env.*
ANTHROPIC_API_KEY.env
*.pem
*.key

# ── Local databases (ephemeral; Cloud Run uses Secret Manager + Cloud SQL) ────
data/tokenomics.db
data/user_reports/
users_vault.db

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Dev tooling ───────────────────────────────────────────────────────────────
.venv/
venv/
env/
.tox/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# ── Docs ──────────────────────────────────────────────────────────────────────
# Exclude markdown docs EXCEPT SYSTEM_PROMPT.md, which the runtime reads via
# ai_narrative._build_system_prompt (expects it at /app/SYSTEM_PROMPT.md).
# Without the negation the bot silently falls back to a 2-line stub prompt,
# losing the analyst persona AND the prompt-injection guardrail.
*.md
!SYSTEM_PROMPT.md
assets/

# NOTE: tests/ is intentionally NOT excluded — the CI test-gate copies it
# into the image and runs `unittest discover` against the exact deployed
# artifact.  Test files are Python-only, tiny, never imported at runtime.

# ── Rust workspace (not part of the Python bot) ───────────────────────────────
rust/

# ── Claude Code session files ─────────────────────────────────────────────────
.claude/
.port_sessions/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
