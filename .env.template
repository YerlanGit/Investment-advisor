# Приложение: claw-code-parity-main
# Переименуйте этот файл в .env и поместите сюда свои секреты

# ПРЕДУПРЕЖДЕНИЕ: НИКОГДА НЕ ПУШЬТЕ ФАЙЛ .env В КОДОВУЮ БАЗУ (GIT).
FINTECH_MASTER_KEY=your_generated_fernet_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Freedom Broker (Tradernet) — read-only API credentials.
# See config/.env.example for full documentation.
TRADERNET_PUBLIC_KEY=
TRADERNET_SECRET_KEY=
FREEDOM_API_KEY=
FREEDOM_API_SECRET=

# Risk-free rate for Sharpe / Sortino calculations.
# For KZ investors the NBK base rate is the correct opportunity cost.
# Default 0.14 (14%). Update whenever the NBK changes its base rate.
KZ_RFR_ANNUAL=0.14
