# Приложение: claw-code-parity-main
# Переименуйте этот файл в .env и поместите сюда свои секреты

# ПРЕДУПРЕЖДЕНИЕ: НИКОГДА НЕ ПУШЬТЕ ФАЙЛ .env В КОДОВУЮ БАЗУ (GIT).
FINTECH_MASTER_KEY=your_generated_fernet_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Freedom Broker (Tradernet) — read-only API credentials.
# See config/.env.example for full documentation.
TRADERNET_PUBLIC_KEY=
TRADERNET_SECRET_KEY=
FREEDOM_API_KEY=
FREEDOM_API_SECRET=

# Risk-free rate for Sharpe / Sortino calculations.
# For KZ investors the NBK base rate is the correct opportunity cost.
# Default 0.14 (14%). Update whenever the NBK changes its base rate.
KZ_RFR_ANNUAL=0.14

# ── FRED (St. Louis Fed macro data) ──────────────────────────────────────────
# Free API key — register at https://fred.stlouisfed.org/docs/api/api_key.html
# Used by src/services/macro_data.py to pull yield curve, HY spread, PMI,
# VIX and breakeven-inflation for the DEEP regime page.  When this is
# empty, the macro_drivers block in the report is rendered with
# status="missing" placeholders — the rest of the pipeline still works.
FRED_API_KEY=

# ── HTML Report Delivery (GCS-backed signed URLs) ────────────────────────────
# Bucket where rendered HTML reports are uploaded.  When empty (e.g. local
# dev without GCP creds) the bot falls back to file:// links and logs a
# warning per call.  Create the bucket once, grant the bot's service
# account roles/storage.objectAdmin.
REPORT_BUCKET_NAME=
# Signed-URL lifetime in hours; default 168 (= 7 days).
REPORT_URL_TTL_HOURS=168

# ── Template version override (rollback knob) ───────────────────────────────
# v3 is the new prototype-grade banker design (default).  Set to v2 to
# roll back to the legacy hybrid (snapshot-bar + q-blocks) layout
# without redeploying code.
# REPORT_DEEP_VERSION=v3
# REPORT_BASIC_VERSION=v3

# Premium V2 report design (React/Tailwind). OFF → classic v3 Jinja templates.
PREMIUM_REPORT_ENABLED=false
